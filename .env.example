# Environment Configuration

# Data
DATA_DIR=./data/raw
IMAGE_SIZE=512

# Model
MODEL_NAME=efficientnet_b4
NUM_CLASSES=5
LEARNING_RATE=0.001
BATCH_SIZE=32
EPOCHS=50

# Device
DEVICE=cuda

# MLOps
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retinopathy-detection
CHECKPOINT_DIR=./models/checkpoints

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Monitoring
PROMETHEUS_PORT=8001
ENABLE_WANDB=true
WANDB_PROJECT=retinopathy-detection

# Paths
LOGS_DIR=./logs
RESULTS_DIR=./results
